# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://devops_user:devops_secret_2026@localhost:5432/devops_platform?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Encryption (for API keys stored in DB) ───────────────────────────────────
ENCRYPTION_KEY="your-32-char-encryption-key-here!"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://devops:devops_mq_2026@localhost:5672"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ─── GitHub OAuth (https://github.com/settings/developers) ───────────────────
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"
GITHUB_REDIRECT_URI="http://localhost:3001/api/github/callback"

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# 1. Create account at https://dashboard.stripe.com
# 2. Get secret key from: Developers → API keys → Secret key
STRIPE_SECRET_KEY="sk_test_..."

# 3. Create products + prices at: Products → Add product
#    One price per plan (recurring, monthly)
STRIPE_PRICE_STARTER="price_..."     # $9/mo
STRIPE_PRICE_PRO="price_..."         # $29/mo
STRIPE_PRICE_ENTERPRISE="price_..."  # Custom

# 4. Set up webhook at: Developers → Webhooks → Add endpoint
#    Endpoint URL: https://your-domain.com/api/billing/webhook
#    Events: checkout.session.completed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── AI Models (optional — agents default to simulation if not set) ───────────
# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI
OPENAI_API_KEY="sk-..."

# Google AI
GOOGLE_AI_API_KEY="AIza..."

# ─── AWS (for real kagent deployments) ───────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_DEFAULT_REGION="us-east-1"
