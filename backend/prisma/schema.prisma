generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────

enum Plan {
  free
  starter
  pro
  enterprise
}

enum DeployStatus {
  pending
  running
  success
  failed
  cancelled
}

enum IncidentStatus {
  active
  investigating
  resolved
}

// ─── Models ──────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  name             String   @default("User")
  avatar           String?
  company          String?
  plan             Plan     @default(free)
  githubToken      String?  @map("github_token") @db.Text
  githubUsername   String?  @map("github_username")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  agentConfigs     AgentConfig[]
  apiKeys          ApiKey[]
  deployments      Deployment[]
  activities       Activity[]
  incidents        Incident[]
  agentExecutions  AgentExecution[]

  @@map("users")
}

model AgentConfig {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  agentId      String  @map("agent_id")
  model        String  @default("gpt-4o-mini")
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(4096) @map("max_tokens")
  customPrompt String? @map("custom_prompt")
  enabled      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@map("agent_configs")
}

model ApiKey {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  provider     String
  encryptedKey String   @map("encrypted_key")
  label        String   @default("")
  isValid      Boolean  @default(true) @map("is_valid")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Deployment {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  projectId   String?      @map("project_id")
  deployId    String       @unique @map("deploy_id")
  projectName String       @map("project_name")
  githubRepo  String?      @map("github_repo")
  githubBranch String?     @map("github_branch")
  status      DeployStatus @default(pending)
  region      String       @default("us-east-1")
  environment String       @default("production")
  budget      Float        @default(0)
  cost        Float        @default(0)
  duration    Int          @default(0)
  stages      String?      @db.Text
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("deployments")
}

model Activity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  text      String
  color     String   @default("#818cf8")
  type      String   @default("info")
  deployId  String?  @map("deploy_id")
  agentId   String?  @map("agent_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activities")
}

model Incident {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  title       String
  description String         @default("")
  alarm       String?
  status      IncidentStatus @default(active)
  resolution  String?
  resolvedAt  DateTime?      @map("resolved_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("incidents")
}

// ─── Agentic AI Models ────────────────────────────

model AgentExecution {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  agentId     String   @map("agent_id")
  task        String   @db.Text
  status      String   @default("running") // running | completed | failed
  steps       String   @default("[]") @db.Text  // JSON array of ReAct steps
  toolCalls   String   @default("[]") @db.Text  // JSON array of tool calls
  result      String?  @db.Text
  durationMs  Int      @default(0) @map("duration_ms")
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@map("agent_executions")
}

model SystemMetrics {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  cpuPercent   Float    @default(0) @map("cpu_percent")
  memPercent   Float    @default(0) @map("mem_percent")
  reqPerSec    Float    @default(0) @map("req_per_sec")
  errorRate    Float    @default(0) @map("error_rate")
  activeConns  Int      @default(0) @map("active_conns")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@index([userId, recordedAt])
  @@map("system_metrics")
}

model ScalingEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   // scale-up-ecs | scale-down-ecs | increase-rds | reduce-cache
  reason      String
  beforeValue Int      @default(1) @map("before_value")
  afterValue  Int      @default(2) @map("after_value")
  appliedBy   String   @default("agent") @map("applied_by") // agent | user
  cost        Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("scaling_events")
}
