# ═══════════════════════════════════════════════════════════════════
# Orbitron Platform — Root Environment Variables
# Copy this file to .env and fill in your values.
# Service-specific env vars are in backend/.env.example
# ═══════════════════════════════════════════════════════════════════

# ─── Docker Compose overrides ────────────────────────────────────────
POSTGRES_PASSWORD=devops_secret_2026
RABBITMQ_PASSWORD=devops_mq_2026

JWT_SECRET=change-me-in-production-min-32-chars!!
ENCRYPTION_KEY=change-me-in-production-32chars!!

# ─── Frontend public URL ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

# ─── GitHub OAuth ────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/github/callback

# ─── Stripe ──────────────────────────────────────────────────────────
# See backend/.env.example for detailed Stripe setup instructions
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_WEBHOOK_SECRET=

# ─── kagent (leave empty for simulation mode) ────────────────────────
KAGENT_API_URL=
