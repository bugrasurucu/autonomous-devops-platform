# ─── Orbitron Environment Configuration ───────────────────────────
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=devops_secret_2026
DATABASE_URL=postgresql://devops_user:devops_secret_2026@localhost:5432/devops_platform?schema=public

# ─── Authentication ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# ─── Encryption (API key storage) ────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-char-random-string

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_PASSWORD=devops_mq_2026
RABBITMQ_URL=amqp://devops:devops_mq_2026@localhost:5672

# ─── GitHub OAuth ─────────────────────────────────────────────────
# Create an OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/github/callback

# ─── CORS / Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Stripe Billing (optional) ───────────────────────────────────
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# ─── Kubernetes / kagent ──────────────────────────────────────────
KAGENT_API_URL=http://kagent-controller.kagent.svc.cluster.local:8083
